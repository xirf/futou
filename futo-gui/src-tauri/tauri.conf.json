{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Futou",
  "version": "0.1.0",
  "identifier": "id.andka.futou",
  "build": {
    "beforeBuildCommand": "cargo build --release -p futou-daemon --manifest-path ../Cargo.toml && bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Futou",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "assets/icons/32x32.png",
      "assets/icons/128x128.png",
      "assets/icons/128x128@2x.png",
      "assets/icons/icon.icns",
      "assets/icons/icon.ico"
    ],
    "resources": {
      "../../target/release/futou-daemon.exe": "bin/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
